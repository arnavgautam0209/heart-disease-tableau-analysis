<?xml version='1.0' encoding='utf-8' ?>
<!--
  Tableau Data Source Configuration
  ==================================
  This .tds file provides a pre-configured connection template for
  connecting Tableau to the Heart Disease database connector.

  Usage:
    1. Start the connector server:  python3 tableau_connector.py
    2. Double-click this .tds file (opens in Tableau Desktop)
    3. Or: Tableau → Data → New Data Source → Web Data Connector
       and enter:  http://localhost:8765/wdc

  Alternative (CSV-based, no server needed):
    1. Open Tableau Desktop
    2. Connect → Text File → navigate to tableau_exports/
    3. Select heart_disease_tableau.csv
-->
<datasource formatted-name='Heart Disease Analysis' inline='true' version='18.1'>
  <connection class='textscan' directory='tableau_exports' filename='heart_disease_tableau.csv' password='' server=''>
    <relation name='heart_disease_tableau' table='[heart_disease_tableau#csv]' type='table'>
      <columns>
        <column datatype='integer' name='record_id' ordinal='1' />
        <column datatype='integer' name='heart_disease' ordinal='2' />
        <column datatype='string'  name='heart_disease_label' ordinal='3' />
        <column datatype='real'    name='bmi' ordinal='4' />
        <column datatype='string'  name='bmi_category' ordinal='5' />
        <column datatype='integer' name='bmi_order' ordinal='6' />
        <column datatype='integer' name='smoking' ordinal='7' />
        <column datatype='integer' name='alcohol_drinking' ordinal='8' />
        <column datatype='integer' name='stroke' ordinal='9' />
        <column datatype='integer' name='diff_walking' ordinal='10' />
        <column datatype='integer' name='physical_activity' ordinal='11' />
        <column datatype='integer' name='asthma' ordinal='12' />
        <column datatype='integer' name='kidney_disease' ordinal='13' />
        <column datatype='integer' name='skin_cancer' ordinal='14' />
        <column datatype='integer' name='physical_health_days' ordinal='15' />
        <column datatype='integer' name='mental_health_days' ordinal='16' />
        <column datatype='real'    name='sleep_hours' ordinal='17' />
        <column datatype='string'  name='sex' ordinal='18' />
        <column datatype='string'  name='age_category' ordinal='19' />
        <column datatype='real'    name='age_midpoint' ordinal='20' />
        <column datatype='integer' name='age_order' ordinal='21' />
        <column datatype='string'  name='race' ordinal='22' />
        <column datatype='string'  name='gen_health' ordinal='23' />
        <column datatype='integer' name='gen_health_score' ordinal='24' />
        <column datatype='integer' name='gen_health_order' ordinal='25' />
        <column datatype='string'  name='diabetic_status' ordinal='26' />
        <column datatype='integer' name='is_diabetic' ordinal='27' />
        <column datatype='integer' name='comorbidity_count' ordinal='28' />
        <column datatype='real'    name='risk_score' ordinal='29' />
        <column datatype='string'  name='risk_tier' ordinal='30' />
      </columns>
    </relation>
  </connection>
  <aliases enabled='yes'>
    <alias key='heart_disease_label' value='Heart Disease' />
    <alias key='bmi_category' value='BMI Category' />
    <alias key='age_category' value='Age Group' />
    <alias key='gen_health' value='General Health' />
    <alias key='risk_tier' value='Risk Tier' />
    <alias key='diabetic_status' value='Diabetic Status' />
    <alias key='physical_health_days' value='Physical Health Days' />
    <alias key='mental_health_days' value='Mental Health Days' />
    <alias key='sleep_hours' value='Sleep Hours' />
    <alias key='comorbidity_count' value='Comorbidity Count' />
    <alias key='risk_score' value='Risk Score' />
    <alias key='diff_walking' value='Difficulty Walking' />
    <alias key='physical_activity' value='Physical Activity' />
    <alias key='alcohol_drinking' value='Alcohol Drinking' />
    <alias key='kidney_disease' value='Kidney Disease' />
    <alias key='skin_cancer' value='Skin Cancer' />
    <alias key='age_midpoint' value='Age (Midpoint)' />
  </aliases>
</datasource>
